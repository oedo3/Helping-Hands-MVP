# ============================================================
# HelpingHands MVP — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# .env.local is NEVER committed to git (see .gitignore).
#
# To get these values:
#   1. Go to https://supabase.com/dashboard
#   2. Select your project
#   3. Go to Project Settings → API
# ============================================================

# ----------------------------------------------------------
# SAFE TO EXPOSE IN BROWSER — Supabase anon/publishable key
# These NEXT_PUBLIC_ vars are bundled into the client JS.
# That is intentional — the anon key is not a secret.
# Security comes from Row Level Security policies in Postgres.
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------------------------
# SERVER-ONLY — Never prefix with NEXT_PUBLIC_
# Used only in server-side API routes or scripts.
# This key bypasses Row Level Security — guard it carefully.
# ----------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
